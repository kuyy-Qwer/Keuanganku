  "categories": ["finance", "productivity", "utilities"],
  "shortcuts": [
    {
      "name": "Tambah Transaksi",
      "short_name": "Tambah",
      "description": "Tambah transaksi baru",
      "url": "/app/wallet?action=add",
      "icons": [{ "src": "/icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Lihat Laporan",
      "short_name": "Laporan",
      "description": "Lihat laporan keuangan",
      "url": "/app/report",
      "icons": [{ "src": "/icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Tabungan",
      "short_name": "Tabungan",
      "description": "Kelola tabungan",
      "url": "/app/savings",
      "icons": [{ "src": "/icon-96x96.png", "sizes": "96x96" }]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+keuanganku",
      "url": "/?url=%s"
    }
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "file_handlers": [
    {
      "action": "/import",
      "accept": {
        "application/json": [".json"],
        "text/csv": [".csv"]
      }
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "id": "com.keuanganku.app"
    },
    {
      "platform": "itunes",
      "id": "id123456789"
    }
  ],
  "prefer_related_applications": false
}