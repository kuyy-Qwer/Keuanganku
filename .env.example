# Salin file ini menjadi .env dan isi nilainya
# File .env TIDAK boleh di-commit ke Git

# Pusher Beams Instance ID (public — aman di frontend)
VITE_PUSHER_INSTANCE_ID=your-instance-id-here

# Pusher Beams Secret Key (RAHASIA — hanya untuk Vercel Function)
# Ambil dari: https://dashboard.pusher.com/beams → Instance → Keys
PUSHER_INSTANCE_ID=your-instance-id-here
PUSHER_SECRET_KEY=your-secret-key-here
